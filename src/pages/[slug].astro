---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const skills = await getCollection('skills')
  return skills.map(s => ({ params: { slug: s.id }, props: { skill: s } }))
}

const { skill } = Astro.props
const { Content } = await render(skill)
const data = skill.data as any
const name = data.name || skill.id
---

<BaseLayout title={`${name} — skills.oriz.in`} description={data.description}>
  <main class="skill-body">
    <p style="color: var(--muted); font-family: var(--font-mono); font-size: 0.8125rem; margin: 0 0 0.5rem;">
      <a href="/" style="color: var(--muted); text-decoration: none;">← skills.oriz.in</a>
    </p>

    <div class="hero-prompt"><span class="sigil">$</span>skill invoke {name}</div>

    <h1>{name}<span class="cursor" aria-hidden="true"></span></h1>
    <p style="color: var(--muted); font-size: 1.0625rem; line-height: 1.55; border-left: 3px solid var(--accent); padding-left: 1rem; margin: 0 0 2rem;">
      {data.description}
    </p>

    <Content />

    <hr />
    <p style="color: var(--muted); font-size: 0.8125rem; font-family: var(--font-mono);">
      <a href={`https://github.com/chirag127/agent-skills/blob/main/${skill.id}/SKILL.md`} style="color: var(--accent);">edit on github</a>
      &nbsp;·&nbsp;
      <a href="/" style="color: var(--accent);">back to toolbox</a>
    </p>
  </main>
</BaseLayout>
